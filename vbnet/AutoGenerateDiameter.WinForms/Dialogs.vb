Public NotInheritable Class ManualCompareDialog
    Inherits Form

    Private ReadOnly _result As CompareResult
    Private ReadOnly _summary As New Label()
    Private ReadOnly _grid As New DataGridView()
    Private ReadOnly _compareBinding As New BindingSource()
    Private ReadOnly _imageView As New CompareImageView()
    Private ReadOnly _crop As New PictureBox()
    Private _allowClose As Boolean

    Public Sub New(result As CompareResult)
        _result = result
        Text = "Manual comparison"
        StartPosition = FormStartPosition.CenterParent
        ClientSize = New Size(1280, 780)
        MinimumSize = New Size(1050, 680)

        _summary = New Label With {
            .Dock = DockStyle.Top,
            .Height = 72,
            .Padding = New Padding(12, 10, 12, 8),
            .Font = New Font("Segoe UI", 12, FontStyle.Bold),
            .AutoEllipsis = True
        }
        UpdateSummary()

        _grid = New DataGridView With {
            .Dock = DockStyle.Fill,
            .ReadOnly = True,
            .AllowUserToAddRows = False,
            .AutoGenerateColumns = False,
            .AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
            .SelectionMode = DataGridViewSelectionMode.FullRowSelect,
            .MultiSelect = True
        }
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "Category", .DataPropertyName = "Category"})
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "Position", .DataPropertyName = "Position"})
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "Expected", .DataPropertyName = "Value"})
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "OCR", .DataPropertyName = "OcrValue"})
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "Confidence", .DataPropertyName = "Confidence"})
        _grid.Columns.Add(New DataGridViewTextBoxColumn With {.HeaderText = "Result", .DataPropertyName = "Result"})
        _compareBinding.DataSource = result.Items
        _grid.DataSource = _compareBinding
        AddHandler _grid.SelectionChanged, AddressOf ShowSelectedItem
        AddHandler _grid.CellFormatting,
            Sub(sender, args)
                If args.RowIndex >= 0 Then
                    Dim item = result.Items(args.RowIndex)
                    If Not item.Comparable Then
                        _grid.Rows(args.RowIndex).DefaultCellStyle.ForeColor = Color.Gray
                    ElseIf item.Result = "MATCH" OrElse item.Result.Contains("CORRECT") OrElse item.Result = "MANUALLY CONFIRMED" Then
                        _grid.Rows(args.RowIndex).DefaultCellStyle.ForeColor = Color.Green
                    Else
                        _grid.Rows(args.RowIndex).DefaultCellStyle.ForeColor = Color.Red
                    End If
                End If
            End Sub

        _imageView.Dock = DockStyle.Fill
        _imageView.ImagePath = result.ImagePath
        _crop.Dock = DockStyle.Fill
        _crop.SizeMode = PictureBoxSizeMode.Zoom
        _crop.BackColor = Color.WhiteSmoke

        Dim images As New SplitContainer With {
            .Dock = DockStyle.Fill,
            .Orientation = Orientation.Horizontal,
            .SplitterDistance = 430
        }
        images.Panel1.Controls.Add(_imageView)
        images.Panel2.Controls.Add(_crop)

        Dim content As New SplitContainer With {.Dock = DockStyle.Fill, .SplitterDistance = 720}
        content.Panel1.Controls.Add(_grid)
        content.Panel2.Controls.Add(images)

        Dim reviewPanel As New TableLayoutPanel With {
            .Dock = DockStyle.Bottom,
            .Height = 62,
            .Padding = New Padding(10),
            .ColumnCount = 2
        }
        reviewPanel.ColumnStyles.Add(New ColumnStyle(SizeType.Percent, 100))
        reviewPanel.ColumnStyles.Add(New ColumnStyle(SizeType.Absolute, 170))
        Dim confirm = New Button With {.Text = "Confirm selected rows", .Dock = DockStyle.Fill}
        AddHandler confirm.Click, AddressOf ConfirmSelected
        reviewPanel.Controls.Add(confirm, 0, 0)
        Dim closeButton = New Button With {.Text = "Close", .Dock = DockStyle.Fill}
        AddHandler closeButton.Click, AddressOf CloseRequested
        reviewPanel.Controls.Add(closeButton, 1, 0)

        Controls.Add(content)
        Controls.Add(reviewPanel)
        Controls.Add(_summary)
        AddHandler FormClosing, AddressOf CheckBeforeClose
        AddHandler Shown, AddressOf ConfirmUnknownFormat
        ShowSelectedItem(Nothing, EventArgs.Empty)
    End Sub

    Private Sub ConfirmUnknownFormat(sender As Object, eventArgs As EventArgs)
        If _result.DetectedFormat <> "UNKNOWN" Then Return
        Using formatDialog As New ManualFormatDialog()
            formatDialog.ShowDialog(Me)
            _result.DetectedFormat = formatDialog.SelectedFormat
        End Using
        For Each item In _result.Items.Where(Function(value) value.Category = "Tray Lot" OrElse value.Category = "Tray Number")
            item.Comparable = _result.DetectedFormat = "NEW"
            item.Status = If(item.Comparable, If(item.OcrValue = "", "MISSING", "MATCH"), "NOT AVAILABLE")
        Next
        _compareBinding.ResetBindings(False)
        UpdateSummary()
    End Sub

    Private Sub UpdateSummary()
        _summary.Text = $"Manual Compare: {If(_result.Verified, "VERIFIED WITH MANUAL CONFIRMATION", "REVIEW REQUIRED")}   Format: {_result.DetectedFormat}" &
            Environment.NewLine &
            $"OCR Match: {_result.FoundCount}   Manual Confirmed: {_result.ManuallyConfirmedCount}   Pending: {_result.PendingCount}"
    End Sub

    Private Function SelectedItem() As CompareItem
        If _grid.CurrentRow Is Nothing Then Return Nothing
        Return TryCast(_grid.CurrentRow.DataBoundItem, CompareItem)
    End Function

    Private Sub ShowSelectedItem(sender As Object, eventArgs As EventArgs)
        Dim item = SelectedItem()
        _imageView.SelectedItem = item
        If _crop.Image IsNot Nothing Then
            _crop.Image.Dispose()
            _crop.Image = Nothing
        End If
        If item Is Nothing OrElse item.WidthRatio <= 0 OrElse String.IsNullOrWhiteSpace(_result.ImagePath) OrElse Not IO.File.Exists(_result.ImagePath) Then Return
        Using source = Image.FromFile(_result.ImagePath)
            Dim left = Math.Clamp(CInt(item.LeftRatio * source.Width), 0, source.Width - 1)
            Dim top = Math.Clamp(CInt(item.TopRatio * source.Height), 0, source.Height - 1)
            Dim width = Math.Clamp(CInt(item.WidthRatio * source.Width), 1, source.Width - left)
            Dim height = Math.Clamp(CInt(item.HeightRatio * source.Height), 1, source.Height - top)
            Dim bitmap As New Bitmap(width, height)
            Using cropGraphics = Graphics.FromImage(bitmap)
                cropGraphics.DrawImage(source, New Rectangle(0, 0, width, height), New Rectangle(left, top, width, height), GraphicsUnit.Pixel)
            End Using
            _crop.Image = bitmap
        End Using
    End Sub

    Private Sub ConfirmSelected(sender As Object, eventArgs As EventArgs)
        Dim selected = _grid.SelectedRows.
            Cast(Of DataGridViewRow)().
            Select(Function(row) TryCast(row.DataBoundItem, CompareItem)).
            Where(Function(item) item IsNot Nothing AndAlso item.Comparable AndAlso item.Status <> "MATCH").
            Cast(Of CompareItem)().
            ToList()
        If selected.Count = 0 Then Return
        For Each item In selected
            item.Resolution = "MANUALLY CONFIRMED"
            item.ConfirmedAt = DateTime.Now
        Next
        _compareBinding.ResetBindings(False)
        UpdateSummary()
        SelectNextPendingItem()
    End Sub

    Private Sub SelectNextPendingItem()
        If _grid.Rows.Count = 0 Then Return
        Dim startIndex = If(_grid.CurrentRow Is Nothing, -1, _grid.CurrentRow.Index)
        For offset = 1 To _grid.Rows.Count
            Dim index = (startIndex + offset) Mod _grid.Rows.Count
            Dim candidate = TryCast(_grid.Rows(index).DataBoundItem, CompareItem)
            If candidate IsNot Nothing AndAlso candidate.NeedsReview Then
                _grid.CurrentCell = _grid.Rows(index).Cells(0)
                Return
            End If
        Next
    End Sub

    Private Sub CloseRequested(sender As Object, eventArgs As EventArgs)
        Close()
    End Sub

    Private Sub CheckBeforeClose(sender As Object, eventArgs As FormClosingEventArgs)
        If _allowClose OrElse _result.PendingCount = 0 Then Return
        Dim choice = MessageBox.Show(
            Me,
            $"There are {_result.PendingCount} unresolved items." & Environment.NewLine &
            "You can continue without confirming all items. Close this window?",
            "Continue with pending items",
            MessageBoxButtons.YesNoCancel,
            MessageBoxIcon.Warning
        )
        If choice = DialogResult.Yes Then
            _allowClose = True
            Return
        End If
        eventArgs.Cancel = True
    End Sub
End Class

