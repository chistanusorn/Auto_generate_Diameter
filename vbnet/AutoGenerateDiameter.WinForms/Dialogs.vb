Public NotInheritable Class CompareImageView
    Inherits Control

    Private _image As Image
    Private _selectedItem As CompareItem

    Public Property ImagePath As String
        Set(value As String)
            If _image IsNot Nothing Then _image.Dispose()
            _image = Nothing
            If Not String.IsNullOrWhiteSpace(value) AndAlso IO.File.Exists(value) Then
                Using source = Image.FromFile(value)
                    _image = New Bitmap(source)
                End Using
            End If
            Invalidate()
        End Set
        Get
            Return ""
        End Get
    End Property

    Public Property SelectedItem As CompareItem
        Set(value As CompareItem)
            _selectedItem = value
            Invalidate()
        End Set
        Get
            Return _selectedItem
        End Get
    End Property

    Protected Overrides Sub OnPaint(e As PaintEventArgs)
        MyBase.OnPaint(e)
        e.Graphics.Clear(Color.FromArgb(235, 238, 242))
        If _image Is Nothing Then Return
        Dim scale = Math.Min(ClientSize.Width / CSng(_image.Width), ClientSize.Height / CSng(_image.Height))
        Dim width = CInt(_image.Width * scale)
        Dim height = CInt(_image.Height * scale)
        Dim x = (ClientSize.Width - width) \ 2
        Dim y = (ClientSize.Height - height) \ 2
        e.Graphics.DrawImage(_image, x, y, width, height)
        If _selectedItem Is Nothing OrElse _selectedItem.WidthRatio <= 0 Then Return
        Dim bounds As New RectangleF(
            CSng(x + _selectedItem.LeftRatio * width),
            CSng(y + _selectedItem.TopRatio * height),
            CSng(_selectedItem.WidthRatio * width),
            CSng(_selectedItem.HeightRatio * height)
        )
        Using pen As New Pen(Color.Red, 3)
            e.Graphics.DrawRectangle(pen, bounds.X, bounds.Y, bounds.Width, bounds.Height)
        End Using
    End Sub

    Protected Overrides Sub Dispose(disposing As Boolean)
        If disposing AndAlso _image IsNot Nothing Then _image.Dispose()
        MyBase.Dispose(disposing)
    End Sub
End Class

