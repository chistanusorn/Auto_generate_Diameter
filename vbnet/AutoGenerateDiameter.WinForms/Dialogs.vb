    Private ReadOnly _capa As New TextBox()
    Private ReadOnly _dome As New TextBox()
    Private ReadOnly _longtail83 As New TextBox()
    Private ReadOnly _longtail95 As New TextBox()
    Private ReadOnly _coatLot As New TextBox()
    Private ReadOnly _operator As New TextBox()
    Private ReadOnly _startTray As New NumericUpDown()

    Public ReadOnly Property ItemValue As String
        Get
            Return _item.Text
        End Get
    End Property

    Public ReadOnly Property PlateNoValue As String
        Get
            Return _plate.Text
        End Get
    End Property

    Public ReadOnly Property DateTimeValue As String
        Get
            Return _dateTime.Text
        End Get
    End Property

    Public ReadOnly Property CapaValue As String
        Get
            Return _capa.Text
        End Get
    End Property

    Public ReadOnly Property DomeTypeValue As String
        Get
            Return _dome.Text
        End Get
    End Property

    Public ReadOnly Property Longtail83Value As String
        Get
            Return _longtail83.Text
        End Get
    End Property

    Public ReadOnly Property Longtail95Value As String
        Get
            Return _longtail95.Text
        End Get
    End Property

    Public ReadOnly Property CoatLotValue As String
        Get
            Return _coatLot.Text
        End Get
    End Property

    Public ReadOnly Property OperatorValue As String
        Get
            Return _operator.Text.Trim()
        End Get
    End Property

    Public ReadOnly Property StartTrayPositionValue As Integer
        Get
            Return CInt(_startTray.Value)
        End Get
    End Property

    Public Sub New(sheet As SheetData)
        Text = "Edit Report Header"
        StartPosition = FormStartPosition.CenterParent
        FormBorderStyle = FormBorderStyle.FixedDialog
        ClientSize = New Size(460, 405)
        Dim layout As New TableLayoutPanel With {.Dock = DockStyle.Fill, .Padding = New Padding(16), .ColumnCount = 2, .RowCount = 11}
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Absolute, 140))
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Percent, 100))
        Controls.Add(layout)
        AddField(layout, "ITEM", _item, sheet.Item, 0)
        AddField(layout, "PLATE No.", _plate, sheet.PlateNo, 1)
        AddField(layout, "DATETIME", _dateTime, sheet.DateTimeStamp, 2)
        AddField(layout, "CAPA.", _capa, sheet.Capa, 3)
        AddField(layout, "DOME Type", _dome, sheet.DomeType, 4)
        AddField(layout, "Longtail 83", _longtail83, sheet.Longtail83, 5)
        AddField(layout, "Longtail 95", _longtail95, sheet.Longtail95, 6)
        AddField(layout, "Coat Lot No.", _coatLot, sheet.CoatLotNo, 7)
        AddField(layout, "Operator", _operator, sheet.OperatorName, 8)
        AddNumber(layout, "Start T-*", _startTray, sheet.StartTrayPosition, 9)
        Dim save = New Button With {.Text = "Save", .DialogResult = DialogResult.OK}
        AddHandler save.Click, AddressOf Submit
        layout.Controls.Add(save, 1, 10)
        AcceptButton = save
    End Sub

    Private Shared Sub AddField(layout As TableLayoutPanel, label As String, entry As TextBox, value As String, row As Integer)
        layout.Controls.Add(New Label With {.Text = label, .AutoSize = True}, 0, row)
        entry.Text = value
        entry.Dock = DockStyle.Fill
        layout.Controls.Add(entry, 1, row)
    End Sub

    Private Shared Sub AddNumber(layout As TableLayoutPanel, label As String, entry As NumericUpDown, value As Integer, row As Integer)
        layout.Controls.Add(New Label With {.Text = label, .AutoSize = True}, 0, row)
        entry.Minimum = 1
        entry.Maximum = 999
        entry.Value = Math.Clamp(value, 1, 999)
        entry.Dock = DockStyle.Fill
        layout.Controls.Add(entry, 1, row)
    End Sub

    Private Sub Submit(sender As Object, eventArgs As EventArgs)
        If String.IsNullOrWhiteSpace(_operator.Text) Then
            MessageBox.Show(Me, "Enter Operator before saving.", "Missing Operator", MessageBoxButtons.OK, MessageBoxIcon.Warning)
            DialogResult = DialogResult.None
        End If
    End Sub
End Class

