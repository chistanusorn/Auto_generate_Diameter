    End Sub
End Class

Public NotInheritable Class StartTrayDialog
    Inherits Form

    Private ReadOnly _startTray As New NumericUpDown()

    Public ReadOnly Property StartTrayPositionValue As Integer
        Get
            Return CInt(_startTray.Value)
        End Get
    End Property

    Public Sub New(currentStartTray As Integer)
        Text = "Adjust data start T"
        StartPosition = FormStartPosition.CenterParent
        FormBorderStyle = FormBorderStyle.FixedDialog
        MaximizeBox = False
        MinimizeBox = False
        ClientSize = New Size(420, 155)

        Dim layout As New TableLayoutPanel With {.Dock = DockStyle.Fill, .Padding = New Padding(16), .ColumnCount = 2, .RowCount = 3}
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Absolute, 140))
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Percent, 100))
        Controls.Add(layout)

        layout.Controls.Add(New Label With {
            .Text = "Data starts at T-*",
            .AutoSize = True
        }, 0, 0)
        _startTray.Minimum = 1
        _startTray.Maximum = 999
        _startTray.Value = Math.Clamp(currentStartTray, 1, 999)
        _startTray.Dock = DockStyle.Fill
        layout.Controls.Add(_startTray, 1, 0)

        Dim note As New Label With {
            .Text = "This moves imported data only. Printed T-1..T-22 positions stay fixed.",
            .AutoSize = True,
            .ForeColor = Color.DarkSlateGray
        }
        layout.Controls.Add(note, 0, 1)
        layout.SetColumnSpan(note, 2)

        Dim buttons As New FlowLayoutPanel With {.Dock = DockStyle.Fill, .FlowDirection = FlowDirection.RightToLeft}
        buttons.Controls.Add(New Button With {.Text = "Apply", .DialogResult = DialogResult.OK})
        buttons.Controls.Add(New Button With {.Text = "Cancel", .DialogResult = DialogResult.Cancel})
        layout.Controls.Add(buttons, 0, 2)
        layout.SetColumnSpan(buttons, 2)
        AcceptButton = buttons.Controls.OfType(Of Button)().First()
        CancelButton = buttons.Controls.OfType(Of Button)().Last()
    End Sub
End Class

Public NotInheritable Class CellEditDialog
    Inherits Form

    Private ReadOnly _mode As New ComboBox()
    Private ReadOnly _diameter As New TextBox()
    Private ReadOnly _trayNumber As New TextBox()
    Private ReadOnly _lotNumber As New TextBox()

    Public ReadOnly Property DisplayModeValue As String
        Get
            Return CStr(_mode.SelectedItem)
        End Get
    End Property

    Public ReadOnly Property DiameterValue As Double
        Get
            Dim value As Double
            Double.TryParse(_diameter.Text.Trim(), NumberStyles.Number, CultureInfo.InvariantCulture, value)
            Return value
        End Get
    End Property

    Public ReadOnly Property TrayNumberValue As String
        Get
            Return _trayNumber.Text.Trim()
        End Get
    End Property

    Public ReadOnly Property LotNumberValue As String
        Get
            Return _lotNumber.Text.Trim()
        End Get
    End Property

    Public Sub New(hit As ReportCellHit, measurement As Measurement)
        Text = $"Edit T-{hit.TrayLabel} Row {hit.RowNumber} {hit.Side}"
        StartPosition = FormStartPosition.CenterParent
        FormBorderStyle = FormBorderStyle.FixedDialog
        MaximizeBox = False
        MinimizeBox = False
        ClientSize = New Size(430, 245)

        Dim layout As New TableLayoutPanel With {
            .Dock = DockStyle.Fill,
            .Padding = New Padding(16),
            .ColumnCount = 2,
            .RowCount = 6
        }
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Absolute, 130))
        layout.ColumnStyles.Add(New ColumnStyle(SizeType.Percent, 100))
        Controls.Add(layout)

        Dim heading As New Label With {
            .Text = $"T-{hit.TrayLabel} / Row {hit.RowNumber} / {hit.Side}",
            .AutoSize = True,
            .Font = New Font("Segoe UI", 11, FontStyle.Bold)
        }
        layout.Controls.Add(heading, 0, 0)
        layout.SetColumnSpan(heading, 2)

        _mode.DropDownStyle = ComboBoxStyle.DropDownList
        _mode.Items.AddRange({"Value", "Dash (-)", "Blank"})
        _mode.SelectedItem = CurrentMode(hit.Side, measurement)
        AddField(layout, "Display", _mode, 1)

        _diameter.Text = CurrentDiameter(hit.Side, measurement)
        AddField(layout, "Diameter", _diameter, 2)

        _trayNumber.Text = If(measurement Is Nothing, "", measurement.TrayNumber)
        AddField(layout, "Tray Number", _trayNumber, 3)

        _lotNumber.Text = If(measurement Is Nothing, "", measurement.LotNumber)
        AddField(layout, "Dip Lot", _lotNumber, 4)

        Dim buttons As New FlowLayoutPanel With {.Dock = DockStyle.Fill, .FlowDirection = FlowDirection.RightToLeft}
        Dim save = New Button With {.Text = "Save", .DialogResult = DialogResult.OK}
        AddHandler save.Click, AddressOf Submit
        buttons.Controls.Add(save)
        buttons.Controls.Add(New Button With {.Text = "Cancel", .DialogResult = DialogResult.Cancel})
        layout.Controls.Add(buttons, 0, 5)
        layout.SetColumnSpan(buttons, 2)

        AddHandler _mode.SelectedIndexChanged, Sub() UpdateDiameterState()
        UpdateDiameterState()
        AcceptButton = save
        CancelButton = buttons.Controls.OfType(Of Button)().Last()
    End Sub

    Private Shared Sub AddField(layout As TableLayoutPanel, label As String, control As Control, row As Integer)
        layout.Controls.Add(New Label With {.Text = label, .AutoSize = True, .Anchor = AnchorStyles.Left}, 0, row)
        control.Dock = DockStyle.Fill
        layout.Controls.Add(control, 1, row)
    End Sub

    Private Shared Function CurrentMode(side As String, measurement As Measurement) As String
        If measurement Is Nothing Then Return "Blank"
        If side = "R" Then
            If measurement.RDash Then Return "Dash (-)"
            If measurement.RPresent Then Return "Value"
            Return "Blank"
        End If
        If measurement.LDash Then Return "Dash (-)"
        If measurement.LPresent Then Return "Value"
        Return "Blank"
    End Function

    Private Shared Function CurrentDiameter(side As String, measurement As Measurement) As String
        If measurement Is Nothing Then Return ""
        Dim value = If(side = "R", measurement.RDiameter, measurement.LDiameter)
        If value = 0 Then Return ""
        Return Math.Round(value).ToString(CultureInfo.InvariantCulture)
    End Function

    Private Sub UpdateDiameterState()
        _diameter.Enabled = DisplayModeValue = "Value"
    End Sub

    Private Sub Submit(sender As Object, eventArgs As EventArgs)
        If DisplayModeValue <> "Value" Then Return
        Dim value As Double
        If Not Double.TryParse(_diameter.Text.Trim(), NumberStyles.Number, CultureInfo.InvariantCulture, value) Then
            MessageBox.Show(Me, "Diameter must be a number.", "Invalid Diameter", MessageBoxButtons.OK, MessageBoxIcon.Warning)
            DialogResult = DialogResult.None
        End If
    End Sub
End Class

